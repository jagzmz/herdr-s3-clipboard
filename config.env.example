# Copy this file to "$(herdr plugin config-dir hsc.s3-clipboard)/.env".
# Choose exactly one namespace: HSC_S3_* or S3_*. Do not mix them.
# If any HSC_S3_* value is present, every required setting must use HSC_S3_*;
# the plugin deliberately refuses to fill missing HSC_S3_* values from S3_*.

# Required credentials and bucket settings.
HSC_S3_BUCKET=images
HSC_S3_ACCESS_KEY_ID=
HSC_S3_SECRET_ACCESS_KEY=

# URL output. Presigned mode keeps the bucket private and accepts an expiry
# from 1 to 604800 seconds (7 days).
HSC_S3_URL_MODE=presigned
HSC_S3_PRESIGN_EXPIRES_IN=604800

# Public mode instead requires a public bucket/CDN origin:
# HSC_S3_URL_MODE=public
# HSC_S3_PUBLIC_BASE_URL=https://img.example.com

# AWS S3 works without an endpoint; set the region instead.
HSC_S3_REGION=us-east-1

# Set an endpoint for another S3-compatible provider such as MinIO, R2,
# Backblaze B2, DigitalOcean Spaces, or Wasabi.
# HSC_S3_ENDPOINT=https://s3.provider.example

# Optional. It can be used in an endpoint template such as:
# HSC_S3_ACCOUNT_ID=your-account-id
# HSC_S3_ENDPOINT=https://{accountId}.r2.cloudflarestorage.com

# Optional upload behavior.
HSC_S3_KEY_PREFIX=images
# HSC_S3_FORCE_PATH_STYLE=true
# HSC_S3_CACHE_CONTROL=public, max-age=31536000, immutable
# HSC_AUTO_SUBMIT=false
